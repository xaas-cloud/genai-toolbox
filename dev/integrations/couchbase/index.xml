<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>Couchbase on MCP Toolbox for Databases</title><link>https://mcp-toolbox.dev/dev/integrations/couchbase/</link><description>Recent content in Couchbase on MCP Toolbox for Databases</description><generator>Hugo</generator><language>en</language><atom:link href="https://mcp-toolbox.dev/dev/integrations/couchbase/index.xml" rel="self" type="application/rss+xml"/><item><title>Couchbase Source</title><link>https://mcp-toolbox.dev/dev/integrations/couchbase/source/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://mcp-toolbox.dev/dev/integrations/couchbase/source/</guid><description>&lt;h2 id="about">About&lt;/h2>
&lt;p>A &lt;code>couchbase&lt;/code> source establishes a connection to a Couchbase database cluster,
allowing tools to execute SQL queries against it.&lt;/p>
&lt;h2 id="available-tools">Available Tools&lt;/h2>








 
 
 
 
 







 &lt;h3>Couchbase Source Tools&lt;/h3>
 
 &lt;table>
 &lt;thead>
 &lt;tr>
 &lt;th>Tool Name&lt;/th>
 &lt;th>Description&lt;/th>
 &lt;/tr>
 &lt;/thead>
 &lt;tbody>
 
 &lt;tr>
 &lt;td>&lt;a href="https://mcp-toolbox.dev/dev/integrations/couchbase/tools/couchbase-sql/">&lt;strong>couchbase-sql&lt;/strong>&lt;/a>&lt;/td>
 &lt;td>A &amp;#34;couchbase-sql&amp;#34; tool executes a pre-defined SQL statement against a Couchbase database.
&lt;/td>
 &lt;/tr>
 
 &lt;/tbody>
 &lt;/table>









